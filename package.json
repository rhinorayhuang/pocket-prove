{
  "name": "classic-snake-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 4173",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "preview:forward": "vite preview --host 0.0.0.0 --port 4177 --strictPort",
    "demo": "npm run build && npm run preview:host",
    "lunel": "npx lunel-cli",
    "lunel:forward": "npx lunel-cli --new --extra-ports 4177",
    "tunnel": "npx localtunnel --port 4177"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  }
}
